# ─────────────────────────────────────────────────────────────────────────────
# Методический кабинет педагога — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site URL ─────────────────────────────────────────────────────────────────
# Public-facing base URL. Used by sitemap, robots, canonical tags, and emails.
# Staging (Replit):   https://metodcab.replit.app
# Production (RU):    https://fop-do.ru
NEXT_PUBLIC_SITE_URL=https://metodcab.replit.app

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase-specific (if using Supabase):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Session / Auth ────────────────────────────────────────────────────────────
# Random secret used to sign session tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32-byte-random-hex

# ── Payments (Prodamus) ───────────────────────────────────────────────────────
# Russian payment provider for one-time purchases and subscriptions.
PRODAMUS_PAYFORM_URL=https://your-shop.payform.ru
PRODAMUS_SECRET_KEY=your-prodamus-secret-key

# ── AI (OpenAI) ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── File Storage (S3-compatible) ──────────────────────────────────────────────
# Compatible with Yandex Object Storage, MinIO, AWS S3, Backblaze B2, etc.
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=metodcab-files
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# ── Email (optional, for notifications) ───────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@fop-do.ru
SMTP_PASS=your-smtp-password
SMTP_FROM="Методический кабинет <noreply@fop-do.ru>"
