# =============================================================================
# Методический кабинет педагога — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# ── Site URL ──────────────────────────────────────────────────────────────────
# Public-facing base URL. Used by sitemap, robots, canonical tags, and emails.
# Staging (Replit):   https://metodcab.replit.app
# Production (RU):    https://fop-do.ru
NEXT_PUBLIC_SITE_URL=https://metodcab.replit.app
APP_ORIGIN=https://metodcab.replit.app
# Optional comma-separated allowlist for additional trusted origins
# (for example admin preview domains or temporary staging domains).
APP_TRUSTED_ORIGINS=


# ── Database (REQUIRED for production) ───────────────────────────────────────
# Primary PostgreSQL connection string.
# Works with any PostgreSQL host: Timeweb, Selectel, Yandex Cloud, Neon, etc.
# Schema: db/migrations/0001_create_core_schema.sql
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname


# ── Supabase (OPTIONAL — prototype / staging only) ────────────────────────────
# Only needed if running on Supabase instead of plain PostgreSQL.
# Supabase migrations are in supabase/migrations/ and depend on auth.users /
# auth.uid() / RLS. They do NOT run on plain PostgreSQL.
# Leave blank for production on Russian-hosted databases.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ── Session / Auth (REQUIRED) ─────────────────────────────────────────────────
# Used to sign httpOnly session cookies (HS256 JWT, 30-day expiry).
# Must be at least 32 bytes of random data.
# Generate a fresh secret with: openssl rand -hex 32
# NEVER reuse this value across environments.
SESSION_SECRET=replace-with-32-byte-random-hex


# ── Payments — Prodamus (REQUIRED for payments) ───────────────────────────────
# Russian payment provider for one-time purchases and subscriptions.
# https://prodamus.ru
PRODAMUS_PAYFORM_URL=https://your-shop.payform.ru
PRODAMUS_SECRET_KEY=your-prodamus-secret-key
# Optional integration code согласованный с поддержкой Prodamus.
# Для самописной интеграции может оставаться пустым, но если поддержка выдаст код,
# его лучше задать явно.
PRODAMUS_SYS=


# ── AI — OpenAI (REQUIRED for AI features) ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ASSISTANT_MODEL=gpt-5-mini


# ── File Storage — S3-compatible (REQUIRED for file delivery) ─────────────────
# Compatible with Yandex Object Storage, MinIO, AWS S3, Backblaze B2, etc.
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=metodcab-files
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key


# ── Email — SMTP (REQUIRED for notifications) ─────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@fop-do.ru
SMTP_PASS=your-smtp-password
SMTP_FROM="Методический кабинет <noreply@fop-do.ru>"
